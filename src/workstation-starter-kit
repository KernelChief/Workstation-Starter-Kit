        self.listbox.add(row)

    def _apply_filter(self, *_):
        q = self.search.get_text().strip().lower()
        for data in self.rows.values():
            f = data["feature"]
            data["row"].set_visible(q in (f["name"] + " " + f["desc"]).lower())

    def set_log(self, text):
        self.textbuf.set_text(text)

    def append_log(self, text):
        end = self.textbuf.get_end_iter()
        self.textbuf.insert(end, text)
        mk = self.textbuf.create_mark(None, self.textbuf.get_end_iter(), True)
        self.textview.scroll_mark_onscreen(mk)

    def _rpm_installed(self, pkg):
        return subprocess.run(["rpm", "-q", pkg], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0

    def _repo_ids(self):
        try:
            p = subprocess.run(["dnf", "-q", "repolist", "--enabled"], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
            out = set()
            for ln in p.stdout.splitlines():
                ln = ln.strip()
                if not ln or ln.lower().startswith("repo id") or ln.lower().startswith("repolist:"):
                    continue
                parts = ln.split()
                if parts:
                    out.add(parts[0])
            return out
        except Exception:
            return set()

    def _service_enabled(self, svc):
        return subprocess.run(["systemctl", "is-enabled", svc], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0

    def _flatpak_installed(self, appid):
        r1 = subprocess.run(["flatpak", "info", "--system", appid], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode
        r2 = subprocess.run(["flatpak", "info", "--user", appid], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode
        return r1 == 0 or r2 == 0

    def _selinux_mode(self):
        try:
            return subprocess.check_output(["getenforce"], text=True).strip().lower()
        except Exception:
            return "unknown"

    def _selinux_config_mode(self):
        cfg = Path("/etc/selinux/config")
        if not cfg.exists():
            return "unknown"
        try:
            for line in cfg.read_text(errors="ignore").splitlines():
                ln = line.strip()
                if not ln or ln.startswith("#"):
                    continue
                if ln.upper().startswith("SELINUX="):
                    return ln.split("=", 1)[1].strip().lower()
        except Exception:
            return "unknown"
        return "unknown"

    def _appimage_present(self, pattern):
        appdirs = [Path.home() / "Applications", Path("/opt/appimages")]
        return any(d.exists() and any(d.glob(pattern)) for d in appdirs)

    def _feature_applied(self, fid, repos):
        f = FEATURE_BY_ID[fid]
        check = f.get("check", {})
        kind = check.get("kind")

        if kind == "rpm":
            return self._rpm_installed(check["pkg"])
        if kind == "rpm_all":
            return all(self._rpm_installed(p) for p in check.get("pkgs", []))
        if kind == "flatpak":
            return self._flatpak_installed(check["appid"])
        if kind == "zram":
            p = Path("/etc/systemd/zram-generator.conf")
            return p.exists() and "compression-algorithm = zstd" in p.read_text(errors="ignore")
        if kind == "repo_and_pkg":
            repo_prefix = check.get("repo_prefix", "")
            repo_file = check.get("repo_file", "")
            has_repo = (repo_prefix and repo_prefix in repos) or (repo_file and Path(repo_file).exists())
            return has_repo and self._rpm_installed(check["pkg"])
        if kind == "tailscale":
            has_repo = any(r.startswith("tailscale") for r in repos) or Path("/etc/yum.repos.d/tailscale.repo").exists()
            return has_repo and self._rpm_installed("tailscale") and self._service_enabled("tailscaled")
        if kind == "pkg_and_service":
            return self._rpm_installed(check["pkg"]) and self._service_enabled(check["service"])
        if kind == "appimage_glob":
            return self._appimage_present(check["pattern"])
        if kind == "appimage_glob_any":
            return any(self._appimage_present(p) for p in check.get("patterns", []))
        return False

    def refresh_states(self):
        repos = self._repo_ids()
        on = 0
        total = len(self.rows)
        for fid, d in self.rows.items():
            applied = self._feature_applied(fid, repos)
            d["applied"] = applied
            if applied:
                on += 1
                d["status"].set_text("✅ Applied")
                d["button"].set_label("Remove")
            else:
                d["status"].set_text("➕ Available")
                d["button"].set_label("Install")
            if not d["busy"]:
                d["button"].set_sensitive(not self.bundle_running)
        if hasattr(self, "selinux_button"):
            runtime_mode = self._selinux_mode()
            config_mode = self._selinux_config_mode()
            if runtime_mode == "disabled" or config_mode == "disabled":
                self.selinux_button.set_label("🛡️ SELinux Disabled ✅")
                self.selinux_button.set_sensitive(False)
            elif runtime_mode == "permissive" or config_mode == "permissive":
                self.selinux_button.set_label("🛡️ SELinux Permissive ✅")
                self.selinux_button.set_sensitive(False)
            else:
                self.selinux_button.set_label("🛡️ Highly Recommended: Set SELinux Permissive")
                self.selinux_button.set_sensitive(not self.bundle_running)
        self._apply_filter()

    def apply_selinux_recommended(self):
        if self.bundle_running:
            return
        runtime_mode = self._selinux_mode()
        config_mode = self._selinux_config_mode()
        if runtime_mode in ("permissive", "disabled") or config_mode in ("permissive", "disabled"):
            return
        mode_choice = "permissive"
        if runtime_mode == "enforcing" or config_mode == "enforcing":
            dlg = Gtk.MessageDialog(
                parent=self,
                flags=0,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.NONE,
                text="SELinux is Enforcing",
            )
            dlg.format_secondary_text(
                "Choose the permanent SELinux mode you want to apply:\n\n"
                "• Permissive: SELinux stays on but does not block actions\n"
                "• Disabled: SELinux is fully disabled\n\n"
                "Both options update /etc/selinux/config permanently."
            )
            dlg.add_button("Cancel", 0)
            dlg.add_button("Set Permissive", 1)
            dlg.add_button("Set Disabled", 2)
            resp = dlg.run()
            dlg.destroy()
            if resp == 1:
                mode_choice = "permissive"
            elif resp == 2:
                mode_choice = "disabled"
            else:
                return
        else:
            dlg = Gtk.MessageDialog(
                parent=self,
                flags=0,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.OK_CANCEL,
                text="Apply SELinux Permissive permanently?",
            )
            dlg.format_secondary_text(
                "This writes SELINUX=permissive in /etc/selinux/config and applies permissive now.\n"
                "This is a permanent change until you manually switch back."
            )
            resp = dlg.run()
            dlg.destroy()
            if resp != Gtk.ResponseType.OK:
                return

        self._toggle_buttons(False)
        self.selinux_button.set_sensitive(False)
        self._run_helper(["set_selinux_mode", mode_choice], on_done=self._selinux_done)

    def _selinux_done(self):
        self._toggle_buttons(True)
        self.selinux_button.set_sensitive(True)
        self.refresh_states()

    def _pick_flatpak_scope(self, appname):
        dlg = Gtk.MessageDialog(parent=self, flags=0, message_type=Gtk.MessageType.QUESTION, buttons=Gtk.ButtonsType.NONE, text=f"Install {appname} via Flatpak")
        dlg.format_secondary_text("Install for current user only, or system-wide for all users?")
        dlg.add_button("User", 1)
        dlg.add_button("System", 2)
        dlg.add_button("Cancel", 0)
        resp = dlg.run()
        dlg.destroy()
        if resp == 1:
            return "user"
        if resp == 2:
            return "system"
        return None

    def on_click(self, fid):
        if self.bundle_running:
            return
        d = self.rows[fid]
        if d["busy"]:
            return

        if fid in FLATPAK_FEATURE_IDS:
            appid = FEATURE_BY_ID[fid]["check"]["appid"]
            if d["applied"]:
                actions = [["remove_flatpak_app", appid]]
                status = "Removing…"
            else:
                scope = self._pick_flatpak_scope(d["feature"]["name"])
                if not scope:
                    return
                actions = [["install_flatpak_app", appid, scope]]
                status = "Installing…"
        else:
            actions = d["feature"].get("remove") if d["applied"] else d["feature"].get("install")
            if not actions:
                return
            status = "Removing…" if d["applied"] else "Installing…"

        self._set_busy(fid, True, status)
        self._run_action_sequence(actions, on_done=lambda: self._done(fid))

    def _set_busy(self, fid, busy, status=None):
        d = self.rows[fid]
        d["busy"] = busy
        d["button"].set_sensitive(not busy and not self.bundle_running)
        if status:
            d["status"].set_text(status)
        if busy:
            d["spinner"].show()
            d["spinner"].start()
        else:
            d["spinner"].stop()
            d["spinner"].hide()

    def _done(self, fid):
        self._set_busy(fid, False)
        self.refresh_states()

    def _run_action_sequence(self, actions, on_done=None):
        queue = [a for a in actions if a]

        def step(i=0):
            if i >= len(queue):
                if on_done:
                    on_done()
                return
            self._run_helper(queue[i], on_done=lambda: step(i + 1))

        step()

    def run_bundle(self, name, ids):
        if self.bundle_running:
            return
        if not self._confirm_bundle(name, ids):
            return
        self.bundle_running = True
        self.append_log(f"\n== Running bundle: {name} ==\n")
        self._toggle_buttons(False)

        repos = self._repo_ids()
        queue = [i for i in ids if i in self.rows and not self._feature_applied(i, repos)]

        def step(i=0):
            if i >= len(queue):
                self.bundle_running = False
                self.append_log(f"== Bundle complete: {name} ==\n")
                self.refresh_states()
                self._toggle_buttons(True)
                return

            fid = queue[i]
            f = FEATURE_BY_ID[fid]
            if fid in FLATPAK_FEATURE_IDS:
                actions = [["install_flatpak_app", f["check"]["appid"], "system"]]
            else:
                actions = f.get("install", [])

            self._set_busy(fid, True, "Installing…")

            def after_feature():
                self._set_busy(fid, False)
                self.refresh_states()
                step(i + 1)

            self._run_action_sequence(actions, on_done=after_feature)

        step()

    def _confirm_bundle(self, name, ids):
        labels = [self.rows[i]["feature"]["name"] for i in ids if i in self.rows]
        msg = "This will apply:\n\n- " + "\n- ".join(labels)
        dlg = Gtk.MessageDialog(
            parent=self,
            flags=0,
            message_type=Gtk.MessageType.QUESTION,
            buttons=Gtk.ButtonsType.OK_CANCEL,
            text=f"Run {name} bundle?",
        )
        dlg.format_secondary_text(msg + "\n\nAdmin password is needed for system changes.")
        resp = dlg.run()
        dlg.destroy()
        return resp == Gtk.ResponseType.OK

    def show_feature_details(self, fid):
        f = FEATURE_BY_ID.get(fid, {})
        items = f.get("contains", [])
        details = "\n".join(f"• {line}" for line in items) if items else "No extra details available."
        dlg = Gtk.MessageDialog(
            parent=self,
            flags=0,
            message_type=Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.OK,
            text=f"{f.get('name', 'Feature')} includes:",
        )
        dlg.format_secondary_text(details)
        dlg.run()
        dlg.destroy()

    def _toggle_buttons(self, enabled):
        for d in self.rows.values():
            if not d["busy"]:
                d["button"].set_sensitive(enabled)

    def _run_helper(self, args, on_done=None):
        if not Path(self.helper).exists():
            self.append_log(f"ERROR: Helper not found: {self.helper}\n")
            if on_done:
                on_done()
            return
        cmd = ["pkexec", self.helper] + args
        self.append_log("\n$ " + " ".join(cmd) + "\n")

        def worker():
            last = deque(maxlen=40)
            try:
                p = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)
                assert p.stdout is not None
                for line in p.stdout:
                    last.append(line)
                    GLib.idle_add(self.append_log, line)
                rc = p.wait()
                GLib.idle_add(self.append_log, f"[exit code: {rc}]\n")
                if rc != 0 and last:
                    GLib.idle_add(self.append_log, "Failed: " + last[-1])
            except Exception as e:
                GLib.idle_add(self.append_log, f"ERROR: {e}\n")
            finally:
                if on_done:
                    GLib.idle_add(on_done)

        threading.Thread(target=worker, daemon=True).start()


def main():
    win = WorkstationStarterKit()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()

        n.set_xalign(0)
        d = Gtk.Label(label=f["desc"])
        d.set_xalign(0)
        d.get_style_context().add_class("subtle")
        left.pack_start(n, False, False, 0)
        left.pack_start(d, False, False, 0)
        box.pack_start(left, True, True, 0)

        st = Gtk.Label(label="Checking…")
        box.pack_start(st, False, False, 0)

        sp = Gtk.Spinner()
        sp.set_no_show_all(True)
        sp.hide()
        box.pack_start(sp, False, False, 0)

        b = Gtk.Button(label="Install")

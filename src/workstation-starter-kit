        box.pack_start(b, False, False, 0)

        details_btn = None
        if f.get("contains"):
            details_btn = Gtk.Button(label="Details")
            details_btn.connect("clicked", lambda *_: self.show_feature_details(fid))
            box.pack_start(details_btn, False, False, 0)

        self.rows[fid] = {
            "feature": f,
            "row": row,
            "status": st,
            "spinner": sp,
            "button": b,
            "details": details_btn,
            "busy": False,
            "applied": False,
